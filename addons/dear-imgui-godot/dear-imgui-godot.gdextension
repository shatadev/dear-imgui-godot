[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/dear-imgui-godot/target/editor/libdear_imgui_godot.so"
linux.release.x86_64 =   "res://addons/dear-imgui-godot/target/release/libdear_imgui_godot.so"
windows.debug.x86_64 =   "res://addons/dear-imgui-godot/target/editor/dear_imgui_godot.dll"
windows.release.x86_64 = "res://addons/dear-imgui-godot/target/release/dear_imgui_godot.dll"
macos.debug =            "res://addons/dear-imgui-godot/target/editor/libdear_imgui_godot.dylib"
macos.release =          "res://addons/dear-imgui-godot/target/release/libdear_imgui_godot.dylib"
macos.debug.arm64 =      "res://addons/dear-imgui-godot/target/editor/libdear_imgui_godot.dylib"
macos.release.arm64 =    "res://addons/dear-imgui-godot/target/release/libdear_imgui_godot.dylib"
web.debug.threads.wasm32 = "res://addons/dear-imgui-godot/target/wasm32-unknown-emscripten/release/dear_imgui_godot.threads.wasm"
web.release.threads.wasm32 = "res://addons/dear-imgui-godot/target/wasm32-unknown-emscripten/release/dear_imgui_godot.threads.wasm"
web.debug.wasm32 = "res://addons/dear-imgui-godot/target/wasm32-unknown-emscripten/release/dear_imgui_godot.wasm"
web.release.wasm32 = "res://addons/dear-imgui-godot/target/wasm32-unknown-emscripten/release/dear_imgui_godot.wasm"
